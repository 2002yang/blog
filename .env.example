# 数据库配置
POSTGRES_DB=blog_prod
POSTGRES_USER=blog_prod
POSTGRES_PASSWORD=change-this-to-strong-password

# JWT 密钥（使用 python3 -c "import secrets; print(secrets.token_urlsafe(32))" 生成）
SECRET_KEY=change-this-to-random-secret-key

# 管理员账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-to-admin-password
ADMIN_EMAIL=admin@yourdomain.com

# CORS 配置（生产环境改为实际域名）
CORS_ORIGINS=["https://yourdomain.com", "https://www.yourdomain.com"]
